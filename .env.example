# Acme Social — variáveis de ambiente
# Copie este arquivo para .env e preencha. NUNCA commite .env (gitignored).

# ─── Anthropic (Claude) ────────────────────────────────────────
# Usado por: ClaudeAdapter (geração), JudgeRunner (eval LLM-as-judge),
#            ClaudeVoiceValidator, BrandValidatorAdapter
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (embeddings — copywriter-agent diversity check) ────
# Usado por: OpenAIEmbeddingsAdapter (text-embedding-3-small)
# OPCIONAL no smoke e dry-run; OBRIGATÓRIO para diversity check em runs reais
OPENAI_API_KEY=sk-...

# ─── Google Vertex AI (Imagen 4 + Veo 3) ───────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_AI_LOCATION=us-central1

# ─── Ideogram v2 (fallback de imagens com texto) ───────────────
IDEOGRAM_API_KEY=ideo-...

# ─── Zernio (publicação multi-rede) ────────────────────────────
ZERNIO_API_KEY=zer-...
ZERNIO_BASE_URL=https://api.zernio.io/v1

# ─── Meta Ads API (Forge-12.4 — Gestor de Tráfego) ─────────────
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=

# ─── LangSmith (telemetria — obrigatório, C6, ADR-006-PROJ) ────
# Usado por: LangSmithAdapter (Observability port — traces e spans).
# Substitui Langfuse desde ADR-006-PROJ.
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=marketing-ai-agents-dev
LANGSMITH_API_URL=https://api.smith.langchain.com
# Quando true, traces sobem para LangSmith. Setar false em CI/test para no-op.
LANGSMITH_TRACING=true

# ─── PostgreSQL (Prisma) ───────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/acme_social

# ─── App config ────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
TENANT_ID_DEFAULT=acme-internal
