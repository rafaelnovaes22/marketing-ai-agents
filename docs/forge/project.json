{
  "$schema": "https://acme.com.br/forge/project-config-v1.json",
  "_doc": "Acme Social — projeto consumidor do agent-governance-framework. Operação 100% autônoma (Forge-11/F27 + Forge-12 Fase 2/F29). 7 agentes IA especializados em marketing digital para 4 redes sociais.",

  "project_config_version": "0.1.0",
  "framework_version_required": ">=0.12.0",
  "constitution_version_required": ">=0.3.0",

  "project": {
    "name": "marketing-ai-agents",
    "owner": "Acme — Rafael de Novaes (founder)",
    "type": "agentic_saas",
    "ai_enabled": true,
    "_comment": "Projeto centrado em agentes de IA com governança de outcome cobrável. 7 SKUs agentic para marketing digital."
  },

  "lifecycle_states": {
    "agentic": ["SHADOW", "ASSISTED", "AUTONOMOUS"],
    "active_default": "agentic"
  },

  "telemetry": {
    "llm_trace_provider": "langfuse",
    "audit_log_provider": "postgres-audit",
    "structured_logging_provider": "pino",
    "metrics_provider": "prometheus"
  },

  "ai_providers": [
    {
      "id": "anthropic-claude-opus-4.6",
      "role": "orchestration_and_strategy",
      "applies_to": ["copywriter", "estrategista"]
    },
    {
      "id": "anthropic-claude-sonnet-4.6",
      "role": "copywriting_and_vision",
      "applies_to": ["social-media", "designer-validation"]
    },
    {
      "id": "anthropic-claude-haiku-4.5",
      "role": "real_time_responses",
      "applies_to": ["atendimento-dm"]
    },
    {
      "id": "google-vertex-imagen-4",
      "role": "image_generation",
      "applies_to": ["designer", "social-media"]
    },
    {
      "id": "google-vertex-veo-3",
      "role": "video_generation",
      "applies_to": ["editor-video"]
    },
    {
      "id": "ideogram-v2",
      "role": "text_in_image_fallback",
      "applies_to": ["designer", "social-media"]
    },
    {
      "id": "elevenlabs-scribe-v2",
      "role": "transcription_premium_pt_br",
      "applies_to": ["editor-video"]
    }
  ],

  "economics_model": "per_outcome",
  "_economics_doc": "Cada agente cobra por outcome entregue. Operação 100% autônoma: founder estratégia + 1 Eng AI manutenção. Investimento Ano 1: R$ 441.490. ROI projetado: 204%.",

  "modules": [
    {
      "id": "social-media-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "draft",
      "outcome_unit": "carrossel_publicado",
      "outcome_price_brl": 12.00,
      "target_sla_seconds": 480,
      "priority": "P0",
      "_doc": "Gera carrossel (5-7 slides) + caption + legenda no tom the CEO em 8 min, para 4 redes (LinkedIn, Instagram, Facebook, Twitter)"
    },
    {
      "id": "copywriter-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "draft",
      "outcome_unit": "landing_ou_email_ou_ad_entregue",
      "outcome_price_brl": 80.00,
      "target_sla_seconds": 900,
      "priority": "P0",
      "_doc": "Landing page completa OU sequência de emails OU 5 variações de anúncio Meta em 15 min"
    },
    {
      "id": "designer-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "draft",
      "outcome_unit": "carrossel_design_completo",
      "outcome_price_brl": 20.00,
      "target_sla_seconds": 1200,
      "priority": "P0",
      "_doc": "Design completo de carrossel (7 slides) com brand Acme 99%+ em 20 min usando Imagen 4 + Ideogram fallback"
    },
    {
      "id": "trafego-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "draft",
      "outcome_unit": "campanha_meta_publicada",
      "outcome_price_brl": 50.00,
      "target_sla_seconds": 300,
      "priority": "P1",
      "_doc": "Campanha Meta completa (criativo + copy + público + orçamento + otimização) em 5 min via Meta Ads API"
    },
    {
      "id": "video-editor-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "draft",
      "outcome_unit": "video_curto_pronto",
      "outcome_price_brl": 30.00,
      "target_sla_seconds": 600,
      "priority": "P1",
      "scope": "cortar_video_longo_input",
      "veo_3_enabled": false,
      "_doc": "ADR-001-PROJ: SKU dedicado a CORTE de vídeo input (live/podcast → Reels/TikTok). NÃO gera vídeo do zero. Veo 3 desabilitado neste SKU. Stack: ElevenLabs Scribe v2 (transcrição) + Claude Sonnet 4.6 (decisão de cortes) + FFmpeg (renderização). Cobre 80% dos casos."
    },
    {
      "id": "video-editor-agent-premium",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "deferred_wave_2",
      "outcome_unit": "video_gerado_do_zero",
      "outcome_price_brl": 150.00,
      "target_sla_seconds": 900,
      "priority": "P2_wave_2",
      "scope": "gerar_video_via_veo3",
      "veo_3_enabled": true,
      "_doc": "ADR-001-PROJ: SKU premium DIFERIDO para wave 2. Gera vídeo do zero via Veo 3. Custo elevado ($0.50/seg) exige re-examinar quando Veo 3 baixar de preço ou demanda real justificar. Re-examinar em 90 dias após AUTONOMOUS do video-editor-agent básico."
    },
    {
      "id": "estrategista-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "B",
      "current_stage": "draft",
      "outcome_unit": "diagnostico_funil_completo",
      "outcome_price_brl": 100.00,
      "target_sla_seconds": 120,
      "priority": "P2",
      "_doc": "Diagnóstico de funil + 3 recomendações acionáveis em 2 min via Mixpanel + Claude Opus"
    },
    {
      "id": "atendimento-dm-agent",
      "type": "agentic_sku",
      "ai_enabled": true,
      "criticality": "A",
      "current_stage": "draft_internal_only",
      "outcome_unit": "lead_qualificado_dm",
      "outcome_price_brl": 5.00,
      "target_sla_seconds": 10,
      "priority": "P2",
      "lgpd_status": "blocked_for_external_tenants",
      "_doc": "ADR-003-PROJ: SHADOW INTERNO-ONLY até Fase 2 LGPD resolvida. Wave 1: apenas DMs internos Acme (founder + staff opt-in). Sem dados de terceiros. ASSISTED/AUTONOMOUS externo BLOQUEADO até DPO ou consultoria LGPD contratada. Retenção 30 dias na Fase 1 (vs 90 final). Risco de multa LGPD (até R$ 50M) > receita perdida (~R$ 9-13K em 2-3 meses)."
    }
  ],

  "integrations": [
    {
      "id": "zernio",
      "role": "social_media_publishing",
      "providers": ["instagram", "facebook", "linkedin", "twitter"]
    },
    {
      "id": "meta-ads-api",
      "role": "ads_campaigns"
    },
    {
      "id": "mixpanel",
      "role": "funnel_analytics"
    },
    {
      "id": "elevenlabs",
      "role": "premium_transcription_pt_br"
    }
  ],

  "tenant_context": {
    "_doc": "Acme Social roda single-tenant inicialmente (a própria Acme). Multi-tenant será adicionado em Forge consumer wave 2 quando vendermos como SaaS para outros founders.",
    "model": "single_tenant_phase_1",
    "future_model": "multi_tenant_per_brand"
  },

  "consumer_declared_at": "2026-05-13",
  "consumer_adopted_phase": "Forge-12 Fase 2 (v0.12.0)",
  "first_module_to_implement": "social-media-agent",
  "implementation_timeline_days": 14
}
