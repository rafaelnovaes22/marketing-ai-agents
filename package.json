{
  "name": "marketing-ai-agents",
  "version": "0.1.0",
  "description": "Acme Social — 7 agentes IA autônomos para marketing digital (consumer agent-governance-framework v0.12.0)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/**/unit",
    "test:integration": "vitest run tests/**/integration",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx src/eval/runner.ts",
    "eval:social-media": "tsx src/eval/runner.ts social-media-agent",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "forge:doctor": "bash scripts/forge doctor",
    "forge:version": "bash scripts/forge version"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google-cloud/aiplatform": "^3.30.0",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@prisma/client": "^6.0.0",
    "js-yaml": "^4.1.0",
    "langsmith": "^0.7.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
